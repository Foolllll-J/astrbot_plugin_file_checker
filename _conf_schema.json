{
    "global_settings": {
        "type": "object",
        "description": "全局设置",
        "hint": "插件的全局基础配置，影响所有群聊。",
        "items": {
            "group_whitelist": {
                "description": "群聊白名单",
                "hint": "仅在白名单里的群启用本插件功能，不填表示所有群都启用。",
                "type": "list",
                "default": []
            },
            "file_size_threshold_mb": {
                "description": "文件处理大小阈值 (MB)",
                "hint": "文件大小超过此值时，将完全跳过该文件的所有处理。设置为 0 则不限制。",
                "type": "int",
                "default": 100
            },
            "process_bot_files": {
                "description": "处理 Bot 自身发送的文件",
                "hint": "开启后，Bot 发送的文件也会走配置的完整处理流程。",
                "type": "bool",
                "default": false
            }
        }
    },
    "check_module": {
        "type": "template_list",
        "description": "文件检查",
        "hint": "配置文件的有效性检查、重复检查及通知行为。",
        "default": [
            {
                "group_id": [],
                "enable_emoji": true,
                "notify_on_success": true,
                "pre_check_delay_seconds": 5,
                "check_delay_seconds": 300,
                "enable_duplicate_check": false
            }
        ],
        "templates": {
            "default": {
                "name": "检查配置",
                "items": {
                    "group_id": {
                        "description": "群号",
                        "hint": "填入群号列表以应用此配置。留空则作为全局默认配置。",
                        "type": "list",
                        "default": []
                    },
                    "enable_emoji": {
                        "description": "启用表情回应",
                        "hint": "开启后，插件会根据文件处理结果在原消息上贴表情回应。",
                        "type": "bool",
                        "default": true
                    },
                    "notify_on_success": {
                        "description": "成功时发送通知",
                        "hint": "开启后，文件检查有效时也会发送一条回复通知。关闭则只在文件失效时通知。",
                        "type": "bool",
                        "default": true
                    },
                    "pre_check_delay_seconds": {
                        "description": "预检延时 (秒)",
                        "hint": "新文件上传后，等待多少秒后进行即时检查，建议 3-10 秒。",
                        "type": "int",
                        "default": 3
                    },
                    "check_delay_seconds": {
                        "description": "复核间隔时间 (秒)",
                        "hint": "即时检查通过后，再等待多少秒进行复核，用于检测后续是否失效。",
                        "type": "int",
                        "default": 300
                    },
                    "enable_duplicate_check": {
                        "description": "启用重复文件检查",
                        "hint": "开启后，新文件上传时将扫描群文件，若有大小完全相同的旧文件将提醒重复并跳过后续处理。",
                        "type": "bool",
                        "default": false
                    },
                    "purify_rules": {
                        "description": "文件名净化规则",
                        "hint": "按正则表达式删除文件名中的内容。例如：\"^\\[广告\\]\" 会删除文件名开头的 [广告]。",
                        "type": "list",
                        "default": []
                    }
                }
            }
        }
    },
    "preview_module": {
        "type": "template_list",
        "description": "文件预览",
        "hint": "配置文本、压缩包、PDF的预览以及媒体文件的转换发送规则。",
        "default": [
            {
                "group_id": [],
                "preview_length": 500,
                "pdf_preview_pages": 0,
                "zip_extraction_size_limit_mb": 0,
                "default_zip_password": "",
                "enable_auto_convert_image": false,
                "auto_convert_video_threshold_mb": 0
            }
        ],
        "templates": {
            "default": {
                "name": "预览配置",
                "items": {
                    "group_id": {
                        "description": "群号",
                        "hint": "填入群号列表以应用此配置。留空则作为全局默认配置。",
                        "type": "list",
                        "default": []
                    },
                    "preview_length": {
                        "description": "文本预览长度 (字符)",
                        "hint": "显示的文本预览最大字符数。设为 0 表示不启用文本预览。",
                        "type": "int",
                        "default": 500
                    },
                    "pdf_preview_pages": {
                        "description": "PDF 预览页数",
                        "hint": "PDF 文件自动生成的预览图页数。默认 0 为不生成。",
                        "type": "int",
                        "default": 0
                    },
                    "zip_extraction_size_limit_mb": {
                        "description": "压缩包预览大小上限 (MB)",
                        "hint": "压缩包超过此大小将不尝试解压预览。默认 0 表示不启用压缩包预览。",
                        "type": "int",
                        "default": 0
                    },
                    "default_zip_password": {
                        "description": "压缩包默认解压密码",
                        "hint": "遇到加密压缩包时尝试使用的密码，留空则不重试。",
                        "type": "string",
                        "default": ""
                    },
                    "enable_auto_convert_image": {
                        "description": "启用图片自动直发",
                        "hint": "开启后，JPG/PNG/GIF 等图片文件（≤15MB）将自动以图片消息重新发送。",
                        "type": "bool",
                        "default": false
                    },
                    "auto_convert_video_threshold_mb": {
                        "description": "视频自动转换阈值 (MB)",
                        "hint": "MP4 视频小于此值时，将自动以视频消息重新发送。0 为不启用。",
                        "type": "int",
                        "default": 0
                    }
                }
            }
        }
    },
    "repack_module": {
        "type": "template_list",
        "description": "文件补档",
        "hint": "配置文件失效后的自动补档逻辑。",
        "default": [
            {
                "group_id": [],
                "repack_file_extensions": "",
                "repack_zip_password": ""
            }
        ],
        "templates": {
            "default": {
                "name": "补档配置",
                "items": {
                    "group_id": {
                        "description": "群号",
                        "type": "list",
                        "default": [],
                        "hint": "填入群号列表以应用此配置。留空则作为全局默认配置。"
                    },
                    "repack_file_extensions": {
                        "description": "支持补档的后缀",
                        "hint": "用逗号分隔，如: txt,pdf。留空则表示对所有格式的文件失效后都进行补档。",
                        "type": "text",
                        "default": ""
                    },
                    "repack_zip_password": {
                        "description": "补档 ZIP 加密密码",
                        "hint": "补档生成的 ZIP 文件所使用的加密密码。",
                        "type": "string",
                        "default": ""
                    }
                }
            }
        }
    },
    "backup_module": {
        "type": "template_list",
        "description": "文件备份",
        "hint": "配置文件备份逻辑，可将文件转发到目标会话。",
        "default": [
            {
                "group_id": [],
                "target_sid": "",
                "backup_extensions": "",
                "only_invalid": false
            }
        ],
        "templates": {
            "default": {
                "name": "备份配置",
                "items": {
                    "group_id": {
                        "description": "群号",
                        "hint": "填入群号列表以应用此配置。留空则作为全局默认配置。",
                        "type": "list",
                        "default": []
                    },
                    "target_sid": {
                        "description": "目标会话 SID",
                        "hint": "文件将备份发送到的目标会话完整 SID。",
                        "type": "string",
                        "default": ""
                    },
                    "backup_extensions": {
                        "description": "备份文件后缀",
                        "hint": "需要备份的文件后缀，用逗号分隔。留空则表示全部文件都备份。",
                        "type": "text",
                        "default": ""
                    },
                    "only_invalid": {
                        "description": "仅备份失效文件",
                        "hint": "开启后只有文件失效时才备份，关闭则所有文件都备份。",
                        "type": "bool",
                        "default": false
                    }
                }
            }
        }
    }
}
